# Copy to .env and fill in. Used by both the app and `docker compose`.

# Local dev DB (relative to the prisma/ folder). In Docker, compose overrides
# this with an absolute path inside the container — you don't need to change it here.
DATABASE_URL="file:./data/app.db"

# REQUIRED in production. Generate one with: openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-secret"

# Session cookie lifetime in days
SESSION_DAYS="7"

# Seed the DB with demo data the first time it boots (Docker only)
SEED_ON_START="true"
